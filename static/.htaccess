# --- 1. Сжатие: отменить gzip для уже сжатых форматов ---
# Родительский ~/.htaccess (контролируется REG.RU) ставит
# `SetOutputFilter DEFLATE` универсально — он жмёт всё, включая PNG/WebP/JPEG.
# AddOutputFilterByType ниже его не отменяет (это разные директивы),
# поэтому используем SetEnvIfNoCase + no-gzip — это снимает фильтр для
# бинарных форматов.

<IfModule mod_setenvif.c>
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|avif|ico|woff2?|mp4|webm|zip|gz|br)$ no-gzip dont-vary
</IfModule>

<IfModule mod_deflate.c>
    # Явно подтверждаем gzip для текстовых типов (на случай, если родитель
    # вдруг ужесточится в будущем).
    AddOutputFilterByType DEFLATE text/html text/css text/xml text/plain
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/xml application/rss+xml application/atom+xml
    AddOutputFilterByType DEFLATE application/manifest+json
    AddOutputFilterByType DEFLATE image/svg+xml font/ttf font/otf
</IfModule>

# --- 2. Vary: перебить родительский ~/.htaccess (он добавляет User-Agent) ---
<IfModule mod_headers.c>
    Header unset Vary
    Header set Vary "Accept-Encoding"

    # --- 3. Cache-Control ---
    # HTML — короткий TTL, ревалидация по ETag/Last-Modified
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=300, must-revalidate"
    </FilesMatch>
    # CSS/JS — fingerprinted Hugo'й, immutable на год
    <FilesMatch "\.(css|js|woff2?|ttf|otf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # Картинки — на 30 дней
    <FilesMatch "\.(png|jpe?g|webp|avif|svg|ico)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>

# --- 4. mod_expires как fallback (если mod_headers где-то не сработает) ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html                 "access plus 5 minutes"
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType image/png                 "access plus 30 days"
    ExpiresByType image/webp                "access plus 30 days"
    ExpiresByType image/avif                "access plus 30 days"
    ExpiresByType image/svg+xml             "access plus 30 days"
</IfModule>

# --- 5. HTTPS canonical: НЕ ВКЛЮЧАТЬ через mod_rewrite ---
# На REG.RU nginx-фронт терминирует TLS и проксирует на Apache по HTTP,
# поэтому %{HTTPS} в Apache ВСЕГДА = off, и любой redirect "off → https://"
# создаст бесконечную петлю. Правильная HTTPS-канонизация уже делается
# на уровне nginx-фронта REG.RU. Если когда-то потребуется делать это
# в .htaccess — использовать %{HTTP:X-Forwarded-Proto} !https, предварительно
# проверив, какой именно header проксирует фронт.

# --- 6. Кастомная 404 (Hugo генерирует /404.html) ---
ErrorDocument 404 /404.html
