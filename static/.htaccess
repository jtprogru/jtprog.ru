# jtprog.ru — Apache .htaccess для REG.RU shared (Apache 2.4.66 + cPanel).
# Цель: gzip-фильтры, Cache-Control, корректный Vary, HTTPS canonical.
# Brotli (mod_brotli) на REG.RU shared НЕ установлен — пропускаем.
# Подробный план: plans/performance-improvement-plan.md (раздел P0, пункт 0).

# --- 0. 301-редиректы: посты переехали из / в /posts/ ---
# Старые URL (/<slug>/) активно ранжируются в поиске — отдаём постоянный 301
# на новый путь /posts/<slug>/. Явный allowlist по slug: НЕ задевает корневые
# страницы (/about-me/, /donations/, ...) и таксономии (/tags/, /categories/).
# Дублируется Hugo-aliases (meta-refresh) как in-repo резерв на случай смены хостинга.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule "^add-disk-lvm/?$" "/posts/add-disk-lvm/" [R=301,L]
    RewriteRule "^after-50-interview/?$" "/posts/after-50-interview/" [R=301,L]
    RewriteRule "^amarok-on-mysql/?$" "/posts/amarok-on-mysql/" [R=301,L]
